# ─── Database ────────────────────────────────────────────────────────────────
# Same Postgres instance as peopleCore — admin app is a read/write consumer,
# never runs prisma migrate.
DATABASE_URL="postgresql://user:password@localhost:5432/peoplecore"

# ─── Clerk authentication ────────────────────────────────────────────────────
# Get keys from https://dashboard.clerk.com → API Keys
# Use the "development" instance for local dev / Vercel preview.
# Use the "production" instance for Vercel production.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Where users land after a successful sign-in (Clerk's hosted flow returns here).
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/tenants"

# ─── Iron Session ─────────────────────────────────────────────────────────────
# 32-char minimum secret for encrypting the temp-password flash cookie.
IRON_SESSION_SECRET="your-32-char-minimum-secret-here"

# ─── PeopleCore integration ───────────────────────────────────────────────────
# URL of the PeopleCore app — used to construct the impersonation handoff POST
# and the exit-impersonation callback URL.
PEOPLECORE_URL="https://hr.224tech.com"

# URL of THIS admin app — sent to PeopleCore as the impersonation exit callback.
ADMIN_APP_URL="https://admin-people-core.vercel.app"

# ─── Deployment notes ─────────────────────────────────────────────────────────
# HTTPS is a hard requirement — never serve this app over HTTP.
# Production: enable Vercel Standard Protection on preview deploys
# so dev Clerk keys aren't reachable from public preview URLs.
