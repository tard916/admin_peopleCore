# ─── Database ────────────────────────────────────────────────────────────────
# Same Postgres instance as peopleCore — admin app is a read/write consumer,
# never runs prisma migrate.
DATABASE_URL="postgresql://user:password@localhost:5432/peoplecore"

# ─── Auth ────────────────────────────────────────────────────────────────────
# MUST match peopleCore's AUTH_SECRET — both apps share the same DB and
# derive encryption keys from this value.
AUTH_SECRET="your-auth-secret-here"

# Admin app uses a distinct cookie name to prevent browser-level confusion
# with peopleCore's authjs.session-token cookie.
# Set automatically by the auth config; document here for ops clarity.
# ADMIN_COOKIE_NAME="adminjs.session-token"

# ─── Rate limiting (Upstash Redis) ───────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ─── PeopleCore integration ───────────────────────────────────────────────────
# URL of the PeopleCore app — used to construct the impersonation handoff POST
# and the exit-impersonation callback URL.
PEOPLECORE_URL="https://app.peoplecore.io"

# URL of THIS admin app — sent to PeopleCore as the impersonation exit callback.
ADMIN_APP_URL="https://admin.peoplecore.io"

# ─── Iron Session ─────────────────────────────────────────────────────────────
# 32-char minimum secret for encrypting the temp-password flash cookie.
IRON_SESSION_SECRET="your-32-char-minimum-secret-here"

# ─── Deployment notes ─────────────────────────────────────────────────────────
# HTTPS is a hard requirement — never serve this app over HTTP.
# Network access must be restricted to the 224tech office IP range / VPN
# at the CDN/load-balancer layer BEFORE this application layer auth.
